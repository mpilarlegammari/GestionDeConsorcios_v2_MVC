@model IEnumerable<Pago>
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Pagos";
    var rol = Context.Session.GetString("UsuarioRol");
        Layout = "~/Views/Shared/_LayoutPropietario.cshtml";
}

<section class="page-intro">
    <div>
        <h2>Pagos</h2>
        <p>Registro y consulta de pagos de expensas.</p>
    </div>
        <a class="btn btn-primary" asp-action="Create">Informar Pago</a>

</section>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">No hay datos para mostrar.</div>
}
else
{
    <table class="table table-clean">
    <thead>
        <tr>
            <th>
                @Html.DisplayName("Fecha")
            </th>
            <th>
                    @Html.DisplayName("Monto")
            </th>
            <th>
                    @Html.DisplayName("Medio de pago")
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Estado)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Comentarios)
            </th>
                <th>Comprobante</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                        @item.FechaPago.ToString("dd/MM/yyyy")
            </td>
            <td>
                @Html.DisplayFor(model => item.MontoPagado)
            </td>
            <td>
                @Html.DisplayFor(model => item.MedioPago)
            </td>
            <td>
                @Html.DisplayFor(model => item.Estado)
            </td>
            <td>
                @Html.DisplayFor(model => item.Comentarios)
            </td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(item.ComprobantePath))
                        {
                            <a href="@Url.Content(item.ComprobantePath)"
                               target="_blank"
                               rel="noopener"
                               class="btn btn-sm btn-outline-primary">
                                Ver comprobante
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">Sin comprobante</span>
                        }
                    </td>
                    <td>
                        <div class="table-actions">
                <a asp-action="Details" asp-route-id="@item.Id">Detalles</a>
                        </div>
            </td>
        </tr>
}
    </tbody>
    </table>
}
