@model IEnumerable<Gasto>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_LayoutPropietario.cshtml";
}


<section class="page-intro">
    <div>
        <h2>Gastos</h2>
        <p>Consulta de gastos del consorcio.</p>
    </div>
</section>

<p>Listado de gastos</p>
@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">No hay datos para mostrar.</div>
}
else
{
    <table class="table table-clean">
    <thead>
        <tr>
            <th>
                @Html.DisplayName("Numero de factura")
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Fecha)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Monto)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Concepto)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Categoria)
            </th>
            <th>
                @Html.DisplayName("Comprobante")
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Descripcion)
            </th>
            <th>
                    @Html.DisplayName("Acciones")
            </th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.NumeroFactura)
            </td>
            <td>
                    @item.Fecha.ToString("dd/MM/yyyy")
            </td>
            <td>
                @Html.DisplayFor(model => item.Monto)
            </td>
            <td>
                @Html.DisplayFor(model => item.Concepto)
            </td>
            <td>
                @Html.DisplayFor(model => item.Categoria)
            </td>
            <td>
                @if (!string.IsNullOrWhiteSpace(item.ArchivoFacturaPath))
                {
                    <a href="@Url.Content(item.ArchivoFacturaPath)"
                       target="_blank"
                       rel="noopener"
                       class="btn btn-sm btn-outline-primary">
                        Ver comprobante
                    </a>
                }
                else
                {
                    <span class="text-muted">Sin comprobante</span>
                }
            </td>
            <td>
                @Html.DisplayFor(model => item.Descripcion)
                        <td>
                            <div class="table-actions">
                                <a asp-action="Details"
                                   asp-route-id="@item.Id">
                                    Detalles
                                </a>
                            </div>
                        </td>
        </tr>
}
    </tbody>
    </table>
}
