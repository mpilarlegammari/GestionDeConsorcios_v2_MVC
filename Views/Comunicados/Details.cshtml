@model Comunicado

@{
    ViewData["Title"] = "Detalles de Comunicado";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<section class="page-intro">
    <div>
        <h2>Detalles de Comunicado</h2>
        <p>Información registrada sobre el comunicado.</p>
    </div>
</section>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Título</dt>
            <dd class="col-sm-9">@Model.Titulo</dd>

            <dt class="col-sm-3">Mensaje</dt>
            <dd class="col-sm-9">@Model.Mensaje</dd>

            <dt class="col-sm-3">Fecha de publicación</dt>
            <dd class="col-sm-9">@Model.FechaPublicacion.ToShortDateString()</dd>

            <dt class="col-sm-3">Archivo adjunto</dt>
            <dd class="col-sm-9">
                @if (!string.IsNullOrEmpty(Model.ArchivoAdjuntoPath))
                {
                    @Model.ArchivoAdjuntoPath
                }
                else
                {
                    <span>-</span>
                }
            </dd>

            <dt class="col-sm-3">Importante</dt>
            <dd class="col-sm-9">
                @if (Model.Importante)
                {
                    <span>Sí</span>
                }
                else
                {
                    <span>No</span>
                }
            </dd>

            <dt class="col-sm-3">Consorcio</dt>
            <dd class="col-sm-9">
                @if (Model.Consorcio != null)
                {
                    @Model.Consorcio.Nombre
                }
                else
                {
                    <span>-</span>
                }
            </dd>
        </dl>

        <div class="mt-3">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
            <a asp-action="Index" class="btn btn-secondary">Volver al listado</a>
        </div>
    </div>
</div>