@model Reclamo

@{
    ViewData["Title"] = "Editar Reclamo";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<section class="page-intro">
    <div>
        <h2>Editar Reclamo</h2>
        <p>Actualizar el estado y la respuesta administrativa del reclamo.</p>
    </div>
</section>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Asunto</dt>
            <dd class="col-sm-9">@Model.Asunto</dd>

            <dt class="col-sm-3">Categoría</dt>
            <dd class="col-sm-9">@Model.Categoria</dd>

            <dt class="col-sm-3">Descripción</dt>
            <dd class="col-sm-9">@Model.Descripcion</dd>

            <dt class="col-sm-3">Fecha de creación</dt>
            <dd class="col-sm-9">@Model.FechaCreacion.ToShortDateString()</dd>

            <dt class="col-sm-3">Unidad funcional</dt>
            <dd class="col-sm-9">
                @if (Model.UnidadFuncional != null)
                {
                    @Model.UnidadFuncional.NumeroUF
                }
                else
                {
                    <span>-</span>
                }
            </dd>
        </dl>

        <hr />

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Estado" class="form-label">Estado</label>
                <select asp-for="Estado" class="form-select" asp-items="Html.GetEnumSelectList<EstadoReclamo>()"></select>
                <span asp-validation-for="Estado" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="FechaCierre" class="form-label">Fecha de cierre</label>
                <input asp-for="FechaCierre" type="date" class="form-control" />
                <span asp-validation-for="FechaCierre" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ObservacionAdministracion" class="form-label">Observación de administración</label>
                <textarea asp-for="ObservacionAdministracion" class="form-control" rows="4"></textarea>
                <span asp-validation-for="ObservacionAdministracion" class="text-danger"></span>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Guardar cambios</button>
                <a asp-action="Index" class="btn btn-secondary">Volver al listado</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}