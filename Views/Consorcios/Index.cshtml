@model IEnumerable<Consorcio>

@{
    ViewData["Title"] = "Consorcio";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<section class="page-intro">
    <div>
        <h2>Consorcios</h2>
        <p>Administracion de edificios y unidades funcionales.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Crear consorcio</a>
</section>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">No hay datos para mostrar.</div>
}
else
{
    <table class="table table-clean">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Nombre)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Direccion)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.UnidadesFuncionales)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.Nombre)
            </td>
            <td>
                @Html.DisplayFor(model => item.Direccion)
            </td>
            <td>
                @Html.DisplayFor(model => item.UnidadesFuncionales)
            </td>
                <td class="table-actions">
                <a asp-action="Edit" asp-route-id="@item.Id">Editar</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Ver detalle</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
