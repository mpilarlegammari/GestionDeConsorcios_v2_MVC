@model IEnumerable<Reserva>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<section class="page-intro">
    <div>
        <h2>Reservas</h2>
        <p>Consultar reservas realizadas por los propietarios</p>
    </div>
</section>


<table class="table table-clean">
    <thead>
        <tr>
            <th>
                @Html.DisplayName("Consorcio")
            </th>
            <th>
                @Html.DisplayName("Amenitie")
            </th>
            <th>
                @Html.DisplayName("Unidad Funcional")
            </th>
            <th>
                @Html.DisplayName("Fecha reserva")
            </th>
            <th>
                @Html.DisplayName("Turno")
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Estado)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @item.UnidadFuncional?.Consorcio?.Nombre
            </td>
            <td>
               @item.Amenity.Nombre
            </td>
            <td>
                @Html.DisplayFor(model => item.UnidadFuncionalId)
            </td>
            <td>
                    @item.FechaReserva.ToString("dd/MM/yyyy")
            </td>
            <td>
                @Html.DisplayFor(model => item.Turno)
            </td>
                <td>
                    @if (item.Estado == EstadoReserva.Pendiente)
                    {
                        <form asp-action="Aprobar"
                              asp-route-id="@item.Id"
                              method="post"
                              class="d-inline">

                            <button type="submit"
                                    class="btn btn-sm btn-warning"
                                    onclick="return confirm('¿Desea aprobar esta reserva?');">
                                Aprobar
                            </button>
                        </form>

                        <form asp-action="Rechazar"
                              asp-route-id="@item.Id"
                              method="post"
                              class="d-inline">

                            <button type="submit"
                                    class="btn btn-sm btn-warning"
                                    onclick="return confirm('¿Desea rechazar esta reserva?');">
                                Rechazar
                            </button>
                        </form>
                    }
                    else if (item.Estado == EstadoReserva.Confirmada)
                    {
                        <span class="badge bg-success">Aprobada</span>
                    }
                    else if (item.Estado == EstadoReserva.Cancelada)
                    {
                        <span class="badge bg-secondary">Cancelada</span>
                    } else
                    {
                        <span class="badge bg-danger">Rechazada</span>
                    }

                    <a asp-action="Details"
                       asp-route-id="@item.Id"
                       class="btn btn-sm btn-outline-secondary">
                        Ver
                    </a>
                </td>
        </tr>
}
    </tbody>
</table>
