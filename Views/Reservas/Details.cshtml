            @Html.DisplayFor(model => model.AmenityId)
        </dd>
    </dl>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.UnidadFuncionalId)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.UnidadFuncionalId)
        </dd>
    </dl>
        <dt class = "col-sm-2">
