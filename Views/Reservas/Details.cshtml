@model Reserva

@{
    ViewData["Title"] = "Details";

    var rol = Context.Session.GetString("UsuarioRol");
    if (rol == "Administrador")
    {
        Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    }
    else if (rol == "Propietario")
    {
        Layout = "~/Views/Shared/_LayoutPropietario.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_LayoutPropietario.cshtml"; // por defecto
    }
}

<h1>Details</h1>

<div>
    <h4>Reserva</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.AmenityId)
        </dt>
