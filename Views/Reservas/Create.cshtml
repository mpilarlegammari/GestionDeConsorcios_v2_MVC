@model Reserva

@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_LayoutPropietario.cshtml";
}

<h1>Create</h1>

<h4>Reserva</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Amenity" class="form-label"></label>
                <select asp-for="AmenityId" class="form-select" asp-items="@(ViewBag.Amenities as SelectList)">
                    <option value="">Seleccione</option>
                </select>
                <span asp-validation-for="AmenityId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="FechaReserva" class="control-label"></label>
                <input asp-for="FechaReserva" type="date" class="form-control" />
                <span asp-validation-for="FechaReserva" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Turno" class="control-label"></label>
                <select asp-for="Turno" class="form-select"

                asp-items="Html.GetEnumSelectList<Turno>()" >
                    <option value="">Seleccione</option>
                </select>

                <span asp-validation-for="Turno" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Observaciones" class="control-label"></label>
                <input asp-for="Observaciones" class="form-control" />
                <span asp-validation-for="Observaciones" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>
