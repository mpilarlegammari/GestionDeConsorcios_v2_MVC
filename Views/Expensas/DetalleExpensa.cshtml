@model IEnumerable<Expensa>
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Expensas";

    var rol = Context.Session.GetString("UsuarioRol");

    if (rol == "Administrador")
    {
        Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_LayoutPropietario.cshtml";
    }

    var consorcioId = ViewBag.FilterConsorcioId as int?;
    var consorcioNombre = ViewBag.FilterConsorcioNombre as string;
    var periodo = ViewBag.FilterPeriodo as string;
}

<section class="page-intro">
    <div>
        <h2>Expensas</h2>
        <p>Registro y consulta de expensas.</p>
    </div>

    @if (rol == "Administrador")
    {
        <a class="btn btn-primary" asp-action="Generar">Generar Expensas</a>
    }
</section>

@if (consorcioId != null || !string.IsNullOrEmpty(periodo))
{
    <div class="mb-3">
        <strong>Filtrado:</strong>
        @if (consorcioNombre != null) { <span>Consorcio: @consorcioNombre </span> }
        else if (consorcioId != null) { <span>Consorcio Id: @consorcioId </span> }
        @if (!string.IsNullOrEmpty(periodo)) { <span class="ms-3">Período: @periodo </span> }

        <a class="btn btn-sm btn-link ms-3" asp-action="IndexResumen">Volver al resumen</a>
    </div>
}

<table class="table table-clean">
    <thead>
        <tr>
            <th>Periodo</th>
            <th>Fecha de emisión</th>
            <th>Fecha de vencimiento</th>
            <th>Monto total</th>
            <th>Estado</th>
            <th>Unidad funcional</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Periodo</td>
                <td>@item.FechaEmision.ToShortDateString()</td>
                <td>@item.FechaVencimiento.ToShortDateString()</td>
                <td>@item.MontoTotal</td>
                <td>@item.Estado</td>
                <td>
                    @if (item.UnidadFuncional != null)
                    {
                        @item.UnidadFuncional.NumeroUF
                    }
                    else
                    {
                        <span>-</span>
                    }
                </td>
                <td class="table-actions">
                    <a asp-action="Details" asp-route-id="@item.Id">Detalles</a>

                    @if (rol == "Administrador")
                    {
                        <span>|</span>
                        <a asp-action="Edit" asp-route-id="@item.Id">Editar</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>